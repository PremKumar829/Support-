# Copy this file to .env for local testing.
# On Render, don't upload .env â€” instead paste these same keys into
# Render Dashboard â†’ your service â†’ Environment.

# Required
BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather

# Comma-separated Telegram user IDs of bot owners (full control, incl. /addadmin)
OWNER_IDS=111111111,222222222

# Optional â€” used for buttons and the admin quick-contact link
SUPPORT_USERNAME=luvarxp
DAILY_EARNING_URL=https://example.com/daily-earning
CHAT_GROUP_URL=https://t.me/your_group

# Optional â€” require users to join this channel before using the bot.
# Leave blank to disable. Format: @yourchannel (bot must be admin there).
FORCE_JOIN_CHANNEL=

# Optional â€” premium animated custom emoji in bot messages (Bot API 9.4+).
# Only renders if the bot owner's Telegram account has an active Premium
# subscription; otherwise Telegram silently shows the plain fallback emoji,
# so it's safe to leave this blank. Format: name:custom_emoji_id,name:id,...
# See README.md for how to get a custom_emoji_id from an emoji pack.
CUSTOM_EMOJIS=

# Required only in webhook mode (i.e. when deployed on Render).
# Leave blank for local polling-mode testing.
# Set this to your Render service URL, e.g. https://prime-support-bot.onrender.com
WEBHOOK_URL=

# Render sets PORT automatically â€” no need to set this yourself on Render.
PORT=8080
