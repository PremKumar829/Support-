# Copy this file to .env for local testing.
# On Render, don't upload .env — instead paste these same keys into
# Render Dashboard → your service → Environment.

# Required
BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather

# Comma-separated Telegram user IDs of bot owners (full control, incl. /addadmin)
OWNER_IDS=111111111,222222222

# Optional — used for buttons and the admin quick-contact link
SUPPORT_USERNAME=luvarxp
DAILY_EARNING_URL=https://example.com/daily-earning
CHAT_GROUP_URL=https://t.me/your_group

# Optional — require users to join this channel before using the bot.
# Leave blank to disable. Format: @yourchannel (bot must be admin there).
FORCE_JOIN_CHANNEL=

# Required only in webhook mode (i.e. when deployed on Render).
# Leave blank for local polling-mode testing.
# Set this to your Render service URL, e.g. https://prime-support-bot.onrender.com
WEBHOOK_URL=

# Render sets PORT automatically — no need to set this yourself on Render.
PORT=8080
